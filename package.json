{
  "name": "next_template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "RUN_INTEGRATION_TESTS=1 vitest run src/testing/auth.integration.test.ts",
    "test:integration:watch": "RUN_INTEGRATION_TESTS=1 vitest src/testing/auth.integration.test.ts",
    "test:integration:suppliers": "RUN_INTEGRATION_TESTS=1 vitest run src/testing/suppliers.integration.test.ts",
    "test:integration:suppliers:watch": "RUN_INTEGRATION_TESTS=1 vitest src/testing/suppliers.integration.test.ts",
    "test:integration:suppliers-list": "RUN_INTEGRATION_TESTS=1 vitest run src/testing/suppliers-list.integration.test.ts",
    "test:integration:production-requests-list": "RUN_INTEGRATION_TESTS=1 vitest run src/testing/production-requests-list.integration.test.ts",
    "test:integration:production-request-estimate": "RUN_INTEGRATION_TESTS=1 NEXT_PUBLIC_API_URL=http://localhost:8087 vitest run src/testing/production-request-estimate.integration.test.ts",
    "format": "prettier --write .",
    "verify:pos-60-3-browser": "node scripts/verify-pos-60-3-browser.mjs",
    "verify:pos-60-3-qa": "bash scripts/verify-pos-60-3-qa.sh",
    "verify:pos-76-2-browser": "node scripts/verify-pos-76-2-browser.mjs",
    "verify:pos-79-3-browser": "node scripts/verify-pos-79-3-browser.mjs",
    "verify:pos-79-4-browser": "node scripts/verify-pos-79-4-browser.mjs",
    "verify:pos-79-5-browser": "node scripts/verify-pos-79-5-browser.mjs",
    "verify:pos-79-6-browser": "node scripts/verify-pos-79-6-browser.mjs",
    "verify:pos-84-3-browser": "node scripts/verify-pos-84-3-browser.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.79.0",
    "recharts": "^3.9.2",
