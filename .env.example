# Public app name shown in the UI
NEXT_PUBLIC_APP_NAME=Luna POS

# Base URL of the backend API (no trailing slash).
# Local dev: luna_pos_service default port. Production: https://pos-api.cymonevo.com
# (see .env.production — value is inlined at build time for NEXT_PUBLIC_* vars).
NEXT_PUBLIC_API_URL=http://localhost:8087
