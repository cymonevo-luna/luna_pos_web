# Public app name shown in the UI
NEXT_PUBLIC_APP_NAME=Luna POS

# Base URL of the backend API — matches luna_pos_service docker-compose host port (8087)
NEXT_PUBLIC_API_URL=http://localhost:8087

# Optional public URL to the latest Android APK (Nextcloud/deploy artifact)
NEXT_PUBLIC_POS_APP_DOWNLOAD_URL=

# Optional overrides for dedicated testing accounts (non-production only)
# TEST_ADMIN_EMAIL=
# TEST_ADMIN_PASSWORD=
# TEST_MANAGER_EMAIL=
# TEST_MANAGER_PASSWORD=
# TEST_CASHIER_EMAIL=
# TEST_CASHIER_PASSWORD=
# TEST_OPERATIONAL_EMAIL=
# TEST_OPERATIONAL_PASSWORD=
